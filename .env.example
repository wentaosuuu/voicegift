# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_MODE=mock
APP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
PROJECT_ACCESS_PEPPER=replace-with-a-different-random-secret
PROVIDER_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
CRON_SECRET=replace-with-a-random-cron-secret
ADMIN_EMAILS=owner@example.com

# Supabase (use the new publishable/secret keys for new projects)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_AUDIO_BUCKET=voicegift-private

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=USD
PAYPAL_PRICE=9.99

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Lyrics generation (OpenAI Responses API)
OPENAI_API_KEY=
OPENAI_LYRICS_MODEL=gpt-5-mini

# Media generation.
# Use MEDIA_PROVIDER=elevenlabs for the built-in ElevenLabs adapter.
# Use MEDIA_PROVIDER=bridge for a custom asynchronous media-provider bridge.
MEDIA_PROVIDER=bridge
ELEVENLABS_API_KEY=
ELEVENLABS_MUSIC_MODEL_ID=music_v1
ELEVENLABS_SPEECH_TO_SPEECH_MODEL_ID=eleven_multilingual_sts_v2
ELEVENLABS_SPEECH_TO_TEXT_MODEL_ID=scribe_v1
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Replaceable async media provider bridge.
# The bridge must accept the documented payloads and call PROVIDER_CALLBACK_URL.
MEDIA_PROVIDER_BASE_URL=
MEDIA_PROVIDER_API_KEY=
MEDIA_PROVIDER_MUSIC_PATH=/v1/music
MEDIA_PROVIDER_VOICE_PATH=/v1/voice-conversion
MEDIA_PROVIDER_VIDEO_PATH=/v1/lyric-video
MEDIA_PROVIDER_VERIFY_PATH=/v1/verify-voice

# Email
RESEND_API_KEY=
EMAIL_FROM=VoiceGift <songs@example.com>

# Optional observability
SENTRY_DSN=
